# Copy this file to .env and fill it with real values.
# NEVER commit the real .env file to git.

ENVIRONMENT=development
DATABASE_URL=sqlite:///./portfolio.db

# JWT - generate a strong key with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_64_BYTE_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
ALLOWED_HOSTS=localhost,127.0.0.1
WHATSAPP_NUMBER=5548991500921
ADMIN_USERNAME=CHANGE_ME
ADMIN_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
RATE_LIMIT_CONTACT=5/hour
RATE_LIMIT_LOGIN=5/minute